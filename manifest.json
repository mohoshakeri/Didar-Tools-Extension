{
  "manifest_version": 3,
  "name": "Didar Tools",
  "short_name": "Didar Tools",
  "version": "1.0.0",
  "description": "Background tools for Didar CRM.",
  "browser_specific_settings": {
    "gecko": {
      "id": "extension@didar-tools.local",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "strict_min_version": "109.0"
    }
  },
  "permissions": [],
  "host_permissions": [
    "https://app.didar.me/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.didar.me/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/bale.png"
      ],
      "matches": [
        "https://app.didar.me/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
